{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dump public schema (Neon)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dump-public-schema.sh",
      "args": [
        "postgresql://neondb_owner:npg_hQ6Dx5agmvuH@ep-spring-water-aqg2ymy6-pooler.c-8.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require",
        "${workspaceFolder}/schema/public_schema.tsv"
      ],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Show public schema (head 500)",
      "type": "shell",
      "command": "sed",
      "args": ["-n", "1,500p", "${workspaceFolder}/schema/public_schema.tsv"],
      "group": "none",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Dump and show public schema",
      "dependsOrder": "sequence",
      "dependsOn": ["Dump public schema (Neon)", "Show public schema (head 500)"],
      "group": "none"
    }
  ]
}
