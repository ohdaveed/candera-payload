# Database connection string
POSTGRES_URL=postgresql://127.0.0.1:5432/your-database-name
# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE
# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE
# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE
# Admin user seeding (used during deploy via scripts/seed-admin.ts)
# SEED_ADMIN_EMAIL=admin@candera.com
# SEED_ADMIN_PASSWORD=your-strong-password
# SEED_ADMIN_NAME=Admin
# Optional manual multi-user seed script
# SEED_PRIMARY_ADMIN_EMAIL=
# SEED_PRIMARY_ADMIN_PASSWORD=
# SEED_PRIMARY_ADMIN_NAME=
# SEED_SECONDARY_ADMIN_EMAIL=
# SEED_SECONDARY_ADMIN_PASSWORD=
# SEED_SECONDARY_ADMIN_NAME=

# Etsy API v3 — product sync engine (see src/utilities/etsyClient.ts)
ETSY_API_KEY=
ETSY_SHARED_SECRET=
ETSY_REDIRECT_URI=
# Optional: defaults to the Candera shop ID if unset
ETSY_SHOP_ID=

# Supabase — optional archive for form submissions
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# SMTP — for transactional email via Payload/Nodemailer
# SMTP_HOST=smtp.mandrillapp.com
# SMTP_PORT=587
# SMTP_USER=your-mandrill-username
# SMTP_PASS=your-mandrill-api-key
# EMAIL_FROM_ADDRESS=studio@canderacandles.com
# EMAIL_FROM_NAME=Candera Studio
