{
  "name": "with-vercel-website",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "ci": "payload migrate && pnpm build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation vp lint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation vp lint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vp test run --config ./vitest.config.mts",
    "prepare": "vp config"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "@inferencesh/sdk": "^0.6.10",
    "@neondatabase/serverless": "^1.1.0",
    "@payloadcms/admin-bar": "3.85.0",
    "@payloadcms/db-postgres": "3.85.0",
    "@payloadcms/db-vercel-postgres": "3.85.0",
    "@payloadcms/email-nodemailer": "^3.85.0",
    "@payloadcms/live-preview-react": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/plugin-form-builder": "3.85.0",
    "@payloadcms/plugin-nested-docs": "3.85.0",
    "@payloadcms/plugin-redirects": "3.85.0",
    "@payloadcms/plugin-search": "3.85.0",
    "@payloadcms/plugin-seo": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/storage-vercel-blob": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "consola": "^3.4.2",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.1",
    "graphql": "^16.14.0",
    "lucide-react": "1.17.0",
    "next": "16.2.7",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "payload": "3.85.0",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.77.0",
    "react-medium-image-zoom": "^5.4.5",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "sharp": "0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.2",
    "@types/escape-html": "^1.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.5.0",
    "jsdom": "29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "vite-plus": "catalog:",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24.15.0"
  }
}
