      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=EB+Garamond:ital,wght@0,400;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300..500;1,9..40,300..500&family=DM+Mono:wght@400;500&display=swap');\n\n  .hero-bg {\n    background-image: url('/api/local/images/Candera Design System/assets/images/seashell-garden.jpg');\n    background-size: cover;\n    background-position: center top;\n  }\n  .grain-overlay {\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E\");\n    opacity: 0.04;\n    mix-blend-mode: overlay;\n  }\n  .nav-link {\n    font-family: 'DM Sans', system-ui, sans-serif;\n    font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em;\n    color: #5f6459; text-decoration: none; transition: color 150ms;\n  }\n  .nav-link:hover { color: #dd7d52; }\n  .eyebrow {\n    font-family: 'DM Sans', system-ui, sans-serif;\n    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3em; color: #a8502b;\n  }\n  .btn-primary {\n    font-family: 'DM Sans', system-ui, sans-serif;\n    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3em;\n    background: #dd7d52; color: #fff; padding: 16px 32px; border: none; cursor: pointer;\n    text-decoration: none; display: inline-block;\n    transition: background 150ms, transform 120ms cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .btn-primary:hover { background: #a8502b; }\n  .btn-primary:active { transform: scale(0.97); }\n  .card-cta {\n    font-family: 'DM Sans', system-ui, sans-serif;\n    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em;\n    border: 1px solid rgba(240, 235, 227, 0.4); color: #f0ebe3; background: transparent;\n    width: 100%; padding: 12px; cursor: pointer;\n    transition: background 200ms, color 200ms, transform 120ms cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .card-cta:hover { background: #f0ebe3; color: #141412; }\n  .card-cta:active { transform: scale(0.97); }\n  .product-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 800ms cubic-bezier(0.16, 1, 0.3, 1); }\n  .product-img-wrap:hover .product-img { transform: scale(1.06); }\n  .ic-btn {\n    font-family: 'DM Sans', system-ui, sans-serif;\n    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.25em;\n    background: #b28c9c; color: #fff; border: none; padding: 14px 24px; cursor: pointer; white-space: nowrap;\n    transition: background 150ms, transform 120ms cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .ic-btn:hover { background: #8a5e72; }\n  .ic-btn:active { transform: scale(0.97); }\n</style>\n\n\n<div style=\"background:rgba(255,255,255,0.97);backdrop-filter:blur(10px);border-bottom:1px solid rgba(218,204,184,0.35);position:relative;z-index:50;\" data-kid=\"1\">\n  <div style=\"max-width:1280px;margin:0 auto;padding:0 40px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:64px;\" data-kid=\"2\">\n    <div data-kid=\"3\"></div>\n    <a href=\"#\" style=\"font-family:'Fraunces',Georgia,serif;font-weight:700;font-size:22px;letter-spacing:-0.02em;color:#141412;text-decoration:none;justify-self:center;\" data-kid=\"4\">CANDERA</a>\n    <div style=\"display:flex;align-items:center;gap:24px;justify-self:end;\" data-kid=\"5\">\n      <a href=\"#\" class=\"nav-link\" data-kid=\"6\">Collection</a>\n      <span style=\"color:#dacbb8;font-size:12px;\" aria-hidden=\"true\" data-kid=\"7\">|</span>\n      <a href=\"#\" class=\"nav-link\" data-kid=\"8\">The Craft</a>\n      <span style=\"color:#dacbb8;font-size:12px;\" aria-hidden=\"true\" data-kid=\"9\">|</span>\n      <a href=\"#\" class=\"nav-link\" data-kid=\"10\">Scent Quiz</a>\n      <a href=\"#\" aria-label=\"Search\" style=\"color:#5f6459;display:inline-flex;align-items:center;transition:color 150ms;\" onmouseover=\"this.style.color='#dd7d52'\" onmouseout=\"this.style.color='#5f6459'\" data-kid=\"11\">\n        <i data-lucide=\"search\" aria-hidden=\"true\" style=\"width:16px;height:16px;stroke-width:1.5;\" data-kid=\"12\"></i>\n      </a>\n      <a href=\"#\" aria-label=\"Shopping bag\" style=\"color:#5f6459;display:inline-flex;align-items:center;transition:color 150ms;\" onmouseover=\"this.style.color='#dd7d52'\" onmouseout=\"this.style.color='#5f6459'\" data-kid=\"13\">\n        <i data-lucide=\"shopping-bag\" aria-hidden=\"true\" style=\"width:18px;height:18px;stroke-width:1.5;\" data-kid=\"14\"></i>\n      </a>\n    </div>\n  </div>\n</div>\n\n\n<div class=\"hero-bg\" style=\"height:720px;position:relative;overflow:hidden;display:flex;align-items:flex-end;\" data-kid=\"15\">\n  <div style=\"position:absolute;inset:0;background:linear-gradient(to right,rgba(0,0,0,0.65) 45%,rgba(0,0,0,0.18) 100%);\" data-kid=\"16\"></div>\n  <div class=\"grain-overlay\" style=\"position:absolute;inset:0;\" aria-hidden=\"true\" data-kid=\"17\"></div>\n\n  \n  <div style=\"position:relative;z-index:10;max-width:580px;padding:0 80px 88px 80px;\" data-kid=\"18\">\n    <p style=\"font-family:'DM Sans',system-ui,sans-serif;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;color:#dd9a7a;margin:0 0 20px 0;\" data-kid=\"19\">Hand-Poured in the Studio</p>\n    <h1 style=\"font-family:'Fraunces',Georgia,serif;font-style:italic;font-weight:400;font-size:82px;line-height:1.0;letter-spacing:-0.01em;color:#fff;margin:0 0 20px 0;font-optical-sizing:auto;\" data-kid=\"20\">An invitation<br data-kid=\"21\">to slow down.</h1>\n    <p style=\"font-family:'DM Sans',system-ui,sans-serif;font-size:15px;font-weight:300;color:rgba(255,255,255,0.70);margin:0 0 36px 0;line-height:1.6;\" data-kid=\"22\">Limited Release: Batch 014 now curing in the studio.</p>\n    <div style=\"display:flex;align-items:center;gap:28px;flex-wrap:wrap;\" data-kid=\"23\">\n      <a href=\"#\" class=\"btn-primary\" data-kid=\"24\">Explore the Collection</a>\n      <a href=\"#\" style=\"font-family:'DM Sans',system-ui,sans-serif;font-size:12px;color:rgba(255,255,255,0.70);text-decoration:none;letter-spacing:0.05em;transition:color 150ms;\" onmouseover=\"this.style.color='rgba(255,255,255,1)'\" onmouseout=\"this.style.color='rgba(255,255,255,0.70)'\" data-kid=\"25\">Take the Scent Quiz →</a>\n    </div>\n  </div>\n\n  \n  <div style=\"position:absolute;right:80px;bottom:80px;z-index:10;background:rgba(253,251,247,0.93);backdrop-filter:blur(14px);border:1px solid rgba(218,204,184,0.45);padding:24px 28px;width:236px;\" data-kid=\"26\">\n    <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:14px;\" data-kid=\"27\">\n      <div style=\"width:20px;height:1px;background:#dd7d52;\" data-kid=\"28\"></div>\n      <p style=\"font-family:'DM Mono',monospace;font-size:9px;font-weight:500;text-transform:uppercase;letter-spacing:0.2em;color:#a8502b;margin:0;\" data-kid=\"29\">Current Release</p>\n    </div>\n    <p style=\"font-family:'Fraunces',Georgia,serif;font-size:34px;font-weight:700;letter-spacing:-0.02em;color:#141412;margin:0 0 4px 0;font-optical-sizing:auto;\" data-kid=\"30\">Batch 014</p>\n    <p style=\"font-family:'DM Mono',monospace;font-size:11px;color:#5f6459;margin:0 0 16px 0;letter-spacing:0.05em;\" data-kid=\"31\">47 units · hand-poured</p>\n    <div style=\"border-top:1px solid rgba(218,204,184,0.5);padding-top:12px;display:flex;flex-direction:column;gap:8px;\" data-kid=\"32\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;\" data-kid=\"33\">\n        <span style=\"font-family:'DM Sans',sans-serif;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.15em;color:#7a8174;\" data-kid=\"34\">Status</span>\n        <span style=\"font-family:'DM Mono',monospace;font-size:10px;color:#dd7d52;letter-spacing:0.05em;\" data-kid=\"35\">Curing</span>\n      </div>\n      <div style=\"display:flex;justify-content:space-between;align-items:center;\" data-kid=\"36\">\n        <span style=\"font-family:'DM Sans',sans-serif;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.15em;color:#7a8174;\" data-kid=\"37\">Ships</span>\n        <span style=\"font-family:'DM Mono',monospace;font-size:10px;color:#141412;letter-spacing:0.05em;\" data-kid=\"38\">~3 weeks</span>\n      </div>\n    </div>\n  </div>\n</div>\n\n\n<div style=\"background:#141412;padding:120px 0;\" data-kid=\"39\">\n  <div style=\"max-width:1280px;margin:0 auto;padding:0 40px;\" data-kid=\"40\">\n    <div style=\"display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:64px;\" data-kid=\"41\">\n      <div data-kid=\"42\">\n        <p class=\"eyebrow\" style=\"color:rgba(168,80,43,0.85);margin-bottom:14px;\" data-kid=\"43\">The Current Batch</p>\n        <h2 style=\"font-family:'Fraunces',Georgia,serif;font-style:italic;font-weight:400;font-size:48px;line-height:1.05;letter-spacing:-0.01em;color:#f0ebe3;margin:0;font-optical-sizing:auto;\" data-kid=\"44\">Rooted in Earth,<br data-kid=\"45\">Released in Air.</h2>\n      </div>\n      <p style=\"font-family:'EB Garamond',Georgia,serif;font-style:italic;font-size:16px;color:rgba(240,235,227,0.50);line-height:1.75;max-width:360px;margin:0;text-align:right;\" data-kid=\"46\">Each vessel is part of a numbered micro-batch, hand-labeled and inspected for peak botanical clarity.</p>\n    </div>\n\n    \n    <div style=\"display:grid;grid-template-columns:1.35fr 1fr;gap:16px;align-items:start;\" data-kid=\"47\">\n\n      \n      <div style=\"background:#1c1a17;border:1px solid rgba(218,204,184,0.10);\" data-kid=\"48\">\n        <div class=\"product-img-wrap\" style=\"position:relative;aspect-ratio:3/4;overflow:hidden;\" data-kid=\"49\">\n          <img src=\"/api/local/images/Candera Design System/assets/images/seashell-garden.jpg\" alt=\"Seashell Garden Glow\" decoding=\"async\" loading=\"lazy\" class=\"product-img\" data-kid=\"50\">\n          <div style=\"position:absolute;top:16px;left:16px;background:#dd7d52;color:#fff;font-family:'DM Sans',sans-serif;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;padding:4px 10px;\" data-kid=\"51\">Bestseller</div>\n          <div style=\"position:absolute;top:16px;right:16px;font-family:'DM Mono',monospace;font-size:10px;color:rgba(240,235,227,0.65);letter-spacing:0.1em;\" data-kid=\"52\">Batch 001</div>\n        </div>\n        <div style=\"padding:28px;\" data-kid=\"53\">\n          <div style=\"display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;\" data-kid=\"54\">\n            <a href=\"#\" style=\"text-decoration:none;\" onmouseover=\"this.querySelector('h3').style.color='#dd7d52'\" onmouseout=\"this.querySelector('h3').style.color='#f0ebe3'\" data-kid=\"55\">\n              <h3 style=\"font-family:'Fraunces',Georgia,serif;font-style:italic;font-weight:400;font-size:28px;line-height:1.2;color:#f0ebe3;margin:0;font-optical-sizing:auto;transition:color 200ms;\" data-kid=\"56\">Seashell Garden Glow</h3>\n            </a>\n            <span style=\"font-family:'DM Mono',monospace;font-size:16px;color:#f0ebe3;white-space:nowrap;margin-left:16px;\" data-kid=\"57\">$38</span>\n          </div>\n          <p style=\"font-family:'EB Garamond',Georgia,serif;font-style:italic;font-size:16px;color:rgba(240,235,227,0.52);margin:0 0 20px 0;line-height:1.65;\" data-kid=\"58\">Coastal salt, driftwood, and sea breeze — a candle that recalls the hour before the tide turns.</p>\n          <div style=\"display:flex;gap:24px;margin-bottom:20px;border-top:1px solid rgba(218,204,184,0.12);padding-top:16px;\" data-kid=\"59\">\n            <div data-kid=\"60\"><div style=\"font-family:'DM Sans',sans-serif;font-size:8px;font-weight:600;text-transform:uppercase;letter-spacing:0.15em;color:#5f6459;margin-bottom:4px;\" data-kid=\"61\">Top</div><div style=\"font-family:'DM Sans',sans-serif;font-size:12px;color:#f0ebe3;font-weight:300;\" data-kid=\"62\">Sea Breeze</div></div>\n            <div data-kid=\"63\"><div style=\"font-family:'DM Sans',sans-serif;font-size:8px;font-weight:600;text-transform:uppercase;letter-spacing:0.15em;color:#5f6459;margin-bottom:4px;\" data-kid=\"64\">Heart</div><div style=\"font-family:'DM Sans',sans-serif;font-size:12px;color:#f0ebe3;font-weight:300;\" data-kid=\"65\">Driftwood</div></div>\n            <div data-kid=\"66\"><div style=\"font-family:'DM Sans',sans-serif;font-size:8px;font-weight:600;text-transform:uppercase;letter-spacing:0.15em;color:#5f6459;margin-bottom:4px;\" data-kid=\"67\">Base</div><div style=\"font-family:'DM Sans',sans-serif;font-size:12px;color:#f0ebe3;font-weight:300;\" data-kid=\"68\">Salt Air</div></div>\n          </div>\n          <button class=\"card-cta\" aria-label=\"Add Seashell Garden Glow to the ritual\" data-kid=\"69\">Add to the Ritual</button>\n        </div>\n      </div>\n\n      \n      <div style=\"display:flex;flex-direction:column;gap:16px;\" data-kid=\"70\">\n        \n        <div style=\"background:#1c1a17;border:1px solid rgba(218,204,184,0.10);\" data-kid=\"71\">\n          <div class=\"product-img-wrap\" style=\"position:relative;aspect-ratio:16/9;overflow:hidden;\" data-kid=\"72\">\n            <img src=\"/api/local/images/Candera Design System/assets/images/meadowlight-botanical.jpg\" alt=\"Meadowlight Botanical\" decoding=\"async\" loading=\"lazy\" class=\"product-img\" data-kid=\"73\">\n            <div style=\"position:absolute;top:12px;left:12px;background:#fff;color:#141412;font-family:'DM Sans',sans-serif;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;padding:3px 8px;\" data-kid=\"74\">New Release</div>\n            <div style=\"position:absolute;