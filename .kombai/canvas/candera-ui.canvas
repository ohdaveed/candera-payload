      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300..500;1,9..40,300..500&display=swap');\n\n  :root {\n    --vellum: #f5f2ed;\n    --obsidian: #141412;\n    --rose: #b28c9c;\n    --ember: #a8502b;\n    --sage: #5f6459;\n    --sage-text: #5f6459;\n    --stone: #dacbb8;\n    --linen: #fdfbf7;\n    --ash: #e2ddd6;\n    --font-display: 'Fraunces', Georgia, serif;\n    --font-editorial: 'EB Garamond', Georgia, serif;\n    --font-sans: 'DM Sans', system-ui, sans-serif;\n  }\n</style>\n\n<script src=\"https://unpkg.com/lucide@latest/dist/umd/lucide.js\" data-kid=\"1\"></script>\n\n<div style=\"font-family: var(--font-sans); background: var(--vellum); color: var(--obsidian); -webkit-font-smoothing: antialiased;\" data-kid=\"2\">\n\n  \n  <header style=\"background: rgba(253,251,247,0.97); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(218,203,184,0.35); position: relative; z-index: 10;\" data-kid=\"3\">\n    <div style=\"max-width: 1280px; margin: 0 auto; padding: 0 40px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; height: 64px;\" data-kid=\"4\">\n      \n      <div data-kid=\"5\"></div>\n      \n      <a href=\"#\" style=\"font-family: var(--font-display); font-weight: 700; font-size: 23px; letter-spacing: -0.02em; color: var(--obsidian); text-decoration: none; justify-self: center;\" data-kid=\"6\">CANDERA</a>\n      \n      <nav style=\"justify-self: end; display: flex; align-items: center; gap: 24px;\" data-kid=\"7\">\n        <a href=\"#\" style=\"font-family: var(--font-sans); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .2em; color: var(--sage); text-decoration: none;\" data-kid=\"8\">Collection</a>\n        <a href=\"#\" style=\"font-family: var(--font-sans); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .2em; color: var(--sage); text-decoration: none;\" data-kid=\"9\">The Craft</a>\n        <a href=\"#\" style=\"font-family: var(--font-sans); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .2em; color: var(--sage); text-decoration: none;\" data-kid=\"10\">Scent Quiz</a>\n        <button style=\"background: none; border: none; padding: 0; cursor: pointer; color: var(--sage); display: flex; align-items: center;\" aria-label=\"Search\" data-kid=\"11\">\n          <i data-lucide=\"search\" style=\"width: 16px; height: 16px; stroke-width: 1.5;\" data-kid=\"12\"></i>\n        </button>\n        <button style=\"background: none; border: none; padding: 0; cursor: pointer; color: var(--sage); display: flex; align-items: center; position: relative;\" aria-label=\"Cart\" data-kid=\"13\">\n          <i data-lucide=\"shopping-bag\" style=\"width: 18px; height: 18px; stroke-width: 1.5;\" data-kid=\"14\"></i>\n        </button>\n      </nav>\n    </div>\n  </header>\n\n  \n  <section style=\"background: var(--vellum); padding-top: 80px; padding-bottom: 64px;\" data-kid=\"15\">\n    <div style=\"max-width: 1280px; margin: 0 auto; padding: 0 40px;\" data-kid=\"16\">\n      <p style=\"font-family: var(--font-sans); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.35em; color: var(--ember); margin: 0 0 14px 0;\" data-kid=\"17\">The Collection</p>\n      <h1 style=\"font-family: var(--font-display); font-optical-sizing: auto; font-style: italic; font-weight: 400; font-size: clamp(2rem, 3.6vw, 3.25rem); line-height: 1.08; letter-spacing: -0.01em; color: var(--obsidian); margin: 0 0 18px 0;\" data-kid=\"18\">Rooted in Earth, Released in Air.</h1>\n      <p style=\"font-family: var(--font-editorial); font-style: italic; font-weight: 400; font-size: 17px; line-height: 1.7; color: var(--sage-text); max-width: 560px; margin: 0 0 36px 0;\" data-kid=\"19\">Each vessel is part of a numbered micro-batch, hand-labeled and inspected for peak botanical clarity.</p>\n      \n      <div style=\"display: flex; flex-wrap: wrap; gap: 10px; align-items: center;\" data-kid=\"20\">\n        <button style=\"font-family: var(--font-sans); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .15em; padding: 8px 16px; background: var(--obsidian); color: var(--linen); border: 1px solid var(--obsidian); border-radius: 2px; cursor: pointer;\" data-kid=\"21\">All</button>\n        <button style=\"font-family: var(--font-sans); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .15em; padding: 8px 16px; background: transparent; color: var(--sage-text); border: 1px solid var(--stone); border-radius: 2px; cursor: pointer;\" data-kid=\"22\">Coastal &amp; Airy</button>\n        <button style=\"font-family: var(--font-sans); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .15em; padding: 8px 16px; background: transparent; color: var(--sage-text); border: 1px solid var(--stone); border-radius: 2px; cursor: pointer;\" data-kid=\"23\">Fresh &amp; Botanical</button>\n        <button style=\"font-family: var(--font-sans); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .15em; padding: 8px 16px; background: transparent; color: var(--sage-text); border: 1px solid var(--stone); border-radius: 2px; cursor: pointer;\" data-kid=\"24\">Moody &amp; Intimate</button>\n        <button style=\"font-family: var(--font-sans); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .15em; padding: 8px 16px; background: transparent; color: var(--sage-text); border: 1px solid var(--stone); border-radius: 2px; cursor: pointer;\" data-kid=\"25\">Romantic &amp; Soft</button>\n        <button style=\"font-family: var(--font-sans); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .15em; padding: 8px 16px; background: transparent; color: var(--sage-text); border: 1px solid var(--stone); border-radius: 2px; cursor: pointer;\" data-kid=\"26\">Bold &amp; Floral</button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section style=\"background: #fff; padding: 96px 0;\" data-kid=\"27\">\n    <div style=\"max-width: 1280px; margin: 0 auto; padding: 0 40px;\" data-kid=\"28\">\n      <div style=\"display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;\" data-kid=\"29\">\n\n        \n        <div style=\"background: #fff; border-radius: 2px;\" data-kid=\"30\">\n          <div style=\"position: relative; aspect-ratio: 4/5; overflow: hidden;\" data-kid=\"31\">\n            <img src=\"/api/local/images/Candera Design System/assets/images/seashell-garden.jpg\" alt=\"Seashell Garden Glow\" decoding=\"async\" loading=\"lazy\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\" data-kid=\"32\">\n            <span style=\"position: absolute; top: 12px; left: 12px; background: #fff; color: var(--obsidian); padding: 4px 8px; font-family: var(--font-sans); font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .2em; border-radius: 2px;\" data-kid=\"33\">Bestseller</span>\n            <span style=\"position: absolute; top: 14px; right: 12px; font-family: var(--font-sans); font-size: 9px; color: rgba(20,20,18,0.45); font-weight: 500; letter-spacing: .12em;\" data-kid=\"34\">Batch 001</span>\n          </div>\n          <div style=\"padding: 16px 0 0 0;\" data-kid=\"35\">\n            <div style=\"border-top: 1px solid var(--stone); padding-top: 14px; display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid rgba(218,203,184,0.4); padding-bottom: 12px; margin-bottom: 12px;\" data-kid=\"36\">\n              <span style=\"font-family: var(--font-display); font-style: italic; font-weight: 400; font-size: 19px; color: var(--obsidian);\" data-kid=\"37\">Seashell Garden Glow</span>\n              <span style=\"font-family: var(--font-sans); font-size: 14px; font-weight: 300; font-variant-numeric: tabular-nums; color: var(--obsidian);\" data-kid=\"38\">$38.00</span>\n            </div>\n            <div style=\"display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; margin-bottom: 10px;\" data-kid=\"39\">\n              <div data-kid=\"40\"><div style=\"font-family: var(--font-sans); font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: .15em; color: var(--sage); margin-bottom: 2px;\" data-kid=\"41\">Top</div><div style=\"font-family: var(--font-sans); font-size: 11px; color: rgba(20,20,18,0.8);\" data-kid=\"42\">Sea Breeze</div></div>\n              <div data-kid=\"43\"><div style=\"font-family: var(--font-sans); font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: .15em; color: var(--sage); margin-bottom: 2px;\" data-kid=\"44\">Heart</div><div style=\"font-family: var(--font-sans); font-size: 11px; color: rgba(20,20,18,0.8);\" data-kid=\"45\">Driftwood</div></div>\n              <div data-kid=\"46\"><div style=\"font-family: var(--font-sans); font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: .15em; color: var(--sage); margin-bottom: 2px;\" data-kid=\"47\">Base</div><div style=\"font-family: var(--font-sans); font-size: 11px; color: rgba(20,20,18,0.8);\" data-kid=\"48\">Salt Air</div></div>\n            </div>\n            <div style=\"font-family: var(--font-sans); font-size: 10px; color: var(--sage); font-style: italic; margin-bottom: 10px;\" data-kid=\"49\">Coastal &amp; Airy</div>\n            <div style=\"display: flex; align-items: center; gap: 5px; margin-bottom: 16px;\" data-kid=\"50\">\n              <i data-lucide=\"clock\" style=\"width: 12px; height: 12px; stroke-width: 1.5; color: var(--sage);\" data-kid=\"51\"></i>\n              <span style=\"font-family: var(--font-sans); font-size: 11px; color: var(--sage);\" data-kid=\"52\">50 Hours</span>\n            </div>\n            <button style=\"width: 100%; font-fami