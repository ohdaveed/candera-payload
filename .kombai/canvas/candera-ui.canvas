      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300..500;1,9..40,300..500&family=DM+Mono:wght@400;500&display=swap');\n\n  :root {\n    --vellum: #f5f2ed;\n    --obsidian: #141412;\n    --rose: #b28c9c;\n    --ember: #a8502b;\n    --sage: #5f6459;\n    --stone: #dacbb8;\n    --linen: #fdfbf7;\n    --ash: #e2ddd6;\n    --cream: #f0ebe3;\n    --font-display: 'Fraunces', Georgia, serif;\n    --font-editorial: 'EB Garamond', Georgia, serif;\n    --font-sans: 'DM Sans', system-ui, sans-serif;\n    --font-mono: 'DM Mono', monospace;\n  }\n\n  .c-nav-link:hover { color: var(--ember) !important; }\n  .c-footer-link:hover { color: var(--ember) !important; }\n  .c-social-link:hover { color: var(--ember) !important; }\n\n  .hero-img { transition: transform 1200ms cubic-bezier(0.16, 1, 0.3, 1); }\n  .hero-img-wrap:hover .hero-img { transform: scale(1.04); }\n\n  .related-img { transition: transform 800ms cubic-bezier(0.16, 1, 0.3, 1); }\n  .related-card:hover .related-img { transform: scale(1.06); }\n\n  .cta-btn {\n    font-family: var(--font-sans);\n    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .25em;\n    background: var(--cream); color: var(--obsidian);\n    width: 100%; padding: 20px; border: none; cursor: pointer;\n    transition: background 150ms, transform 120ms cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .cta-btn:hover { background: #fff; }\n  .cta-btn:active { transform: scale(0.98); }\n\n  .ic-btn {\n    font-family: var(--font-sans);\n    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .22em;\n    background: var(--rose); color: #fff; border: none;\n    padding: 14px 24px; cursor: pointer; white-space: nowrap;\n    transition: background 150ms, transform 120ms cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .ic-btn:hover { background: #8a5e72; }\n  .ic-btn:active { transform: scale(0.97); }\n\n  .scent-node:hover .scent-dot { background: var(--ember) !important; box-shadow: 0 0 0 3px rgba(168,80,43,0.2); }\n  .scent-node:hover .scent-name { color: #fff !important; }\n</style>\n\n\n<header style=\"background:rgba(20,20,18,0.97);backdrop-filter:blur(10px);border-bottom:1px solid rgba(218,203,184,0.10);position:relative;z-index:50;\" data-kid=\"1\">\n  <div style=\"max-width:1280px;margin:0 auto;padding:0 40px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:64px;\" data-kid=\"2\">\n    <div data-kid=\"3\"></div>\n    <a href=\"#\" style=\"font-family:var(--font-display);font-weight:700;font-size:23px;letter-spacing:-0.02em;color:var(--linen);text-decoration:none;\" data-kid=\"4\">CANDERA</a>\n    <nav style=\"display:flex;align-items:center;gap:24px;justify-self:end;\" data-kid=\"5\">\n      <a href=\"#\" class=\"c-nav-link\" style=\"font-family:var(--font-sans);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.2em;color:rgba(240,235,227,0.55);text-decoration:none;transition:color 150ms;\" data-kid=\"6\">Collection</a>\n      <a href=\"#\" class=\"c-nav-link\" style=\"font-family:var(--font-sans);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.2em;color:rgba(240,235,227,0.55);text-decoration:none;transition:color 150ms;\" data-kid=\"7\">The Craft</a>\n      <a href=\"#\" class=\"c-nav-link\" style=\"font-family:var(--font-sans);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.2em;color:rgba(240,235,227,0.55);text-decoration:none;transition:color 150ms;\" data-kid=\"8\">Scent Quiz</a>\n      <a href=\"#\" class=\"c-nav-link\" style=\"color:rgba(240,235,227,0.55);display:inline-flex;align-items:center;transition:color 150ms;\" data-kid=\"9\">\n        <i data-lucide=\"search\" style=\"width:16px;height:16px;stroke-width:1.5;\" data-kid=\"10\"></i>\n      </a>\n    </nav>\n  </div>\n</header>\n\n\n<section style=\"background:var(--obsidian);display:grid;grid-template-columns:55fr 45fr;\" data-kid=\"11\">\n  \n  <div class=\"hero-img-wrap\" style=\"position:relative;overflow:hidden;min-height:640px;\" data-kid=\"12\">\n    <img src=\"/api/local/images/Candera Design System/assets/images/seashell-garden.jpg\" alt=\"Seashell Garden Glow vessel\" decoding=\"async\" loading=\"lazy\" class=\"hero-img\" style=\"width:100%;height:100%;object-fit:cover;display:block;\" data-kid=\"13\">\n    <span style=\"position:absolute;top:20px;left:20px;background:#fff;color:var(--obsidian);font-family:var(--font-sans);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.25em;padding:5px 10px;\" data-kid=\"14\">Bestseller</span>\n    <span style=\"position:absolute;bottom:20px;left:20px;font-family:var(--font-mono);font-size:9px;color:rgba(240,235,227,0.55);letter-spacing:.12em;text-transform:uppercase;\" data-kid=\"15\">Vessel 001 · Batch 001</span>\n  </div>\n\n  \n  <div style=\"padding:64px 56px;display:flex;flex-direction:column;justify-content:center;background:var(--obsidian);\" data-kid=\"16\">\n    <p style=\"font-family:var(--font-sans);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.3em;color:rgba(168,80,43,0.85);margin:0 0 16px 0;\" data-kid=\"17\">Batch 001 · Coastal &amp; Airy</p>\n\n    <h1 style=\"font-family:var(--font-display);font-optical-sizing:auto;font-style:italic;font-weight:400;font-size:48px;line-height:1.06;letter-spacing:-0.01em;color:var(--cream);margin:0;\" data-kid=\"18\">Seashell Garden Glow.</h1>\n\n    <p style=\"font-family:var(--font-editorial);font-style:italic;font-size:18px;color:rgba(240,235,227,0.50);margin:12px 0 0 0;line-height:1.5;\" data-kid=\"19\">Gathered from the tide. A practice in coastal stillness.</p>\n\n    <div style=\"display:flex;align-items:baseline;gap:10px;margin-top:20px;\" data-kid=\"20\">\n      <span style=\"font-family:var(--font-mono);font-size:26px;color:var(--cream);letter-spacing:.02em;\" data-kid=\"21\">$38</span>\n      <span style=\"font-family:var(--font-sans);font-size:12px;color:rgba(240,235,227,0.40);font-weight:300;\" data-kid=\"22\">15 oz · Soy &amp; beeswax blend</span>\n    </div>\n\n    <div style=\"border-top:1px solid rgba(218,203,184,0.15);margin:24px 0;\" data-kid=\"23\"></div>\n\n    <p style=\"font-family:var(--font-sans);font-size:14px;font-weight:300;line-height:1.75;color:rgba(240,235,227,0.68);margin:0;\" data-kid=\"24\">Capturing the raw, mineral breath of the Pacific. A softly salty sea breeze meets sun-warmed sand at the threshold of dusk. Hand-poured into numbered vessels, adorned with botanicals gathered at the water's edge.</p>\n\n    \n    <div style=\"margin-top:28px;\" data-kid=\"25\">\n      <p style=\"font-family:var(--font-sans);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.28em;color:rgba(240,235,227,0.35);margin:0 0 20px 0;\" data-kid=\"26\">Fragrance Journey</p>\n      <div style=\"display:flex;align-items:flex-start;\" data-kid=\"27\">\n        <div class=\"scent-node\" style=\"display:flex;flex-direction:column;align-items:center;cursor:default;flex-shrink:0;\" data-kid=\"28\">\n          <div class=\"scent-dot\" style=\"width:8px;height:8px;border-radius:50%;background:var(--ember);transition:background 200ms,box-shadow 200ms;\" data-kid=\"29\"></div>\n          <div style=\"font-family:var(--font-sans);font-size:8px;font-weight:600;text-transform:uppercase;letter-spacing:.15em;color:rgba(240,235,227,0.35);margin-top:8px;\" data-kid=\"30\">Top</div>\n          <div class=\"scent-name\" style=\"font-family:var(--font-sans);font-size:12px;color:var(--cream);margin-top:4px;transition:color 200ms;text-align:center;\" data-kid=\"31\">Sea Breeze</div>\n        </div>\n        <div style=\"flex:1;height:1px;background:rgba(218,203,184,0.15);margin:3px 12px 0;\" data-kid=\"32\"></div>\n        <div class=\"scent-node\" style=\"display:flex;flex-direction:column;align-items:center;cursor:default;flex-shrink:0;\" data-kid=\"33\">\n          <div class=\"scent-dot\" style=\"width:8px;height:8px;border-radius:50%;background:var(--rose);transition:background 200ms,box-shadow 200ms;\" data-kid=\"34\"></div>\n          <div style=\"font-family:var(--font-sans);font-size:8px;font-weight:600;text-transform:uppercase;letter-spacing:.15em;color:rgba(240,235,227,0.35);margin-top:8px;\" data-kid=\"35\">Heart</div>\n          <div class=\"scent-name\" style=\"font-family:var(--font-sans);font-size:12px;color:var(--cream);margin-top:4px;transition:color 200ms;text-align:center;\" data-kid=\"36\">Driftwood</div>\n        </div>\n        <div style=\"flex:1;height:1px;background:rgba(218,203,184,0.15);margin:3px 12px 0;\" data-kid=\"37\"></div>\n        <div class=\"scent-node\" style=\"display:flex;flex-direction:column;align-items:center;cursor:default;flex-shrink:0;\" data-kid=\"38\">\n          <div class=\"scent-dot\" style=\"width:8px;height:8px;border-radius:50%;background:rgba(218,203,184,0.45);transition:background 200ms,box-shadow 200ms;\" data-kid=\"39\"></div>\n          <div style=\"font-family:var(--font-sans);font-size:8px;font-weight:600;text-transform:uppercase;letter-spacing:.15em;color:rgba(240,235,227,0.35);margin-top:8px;\" data-kid=\"40\">Base</div>\n          <div class=\"scent-name\" style=\"font-family:var(--font-sans);font-size:12px;color:var(--cream);margin-top:4px;transition:color 200ms;text-align:center;\" data-kid=\"41\">Salt Air</div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div style=\"display:flex;gap:20px;margin-top:20px;flex-wrap:wrap;\" data-kid=\"42\">\n      <span style=\"font-family:var(--font-sans);font-size:9px;text-transform:uppercase;letter-spacing:.15em;color:rgba(240,235,227,0.38);font-weight:600;\" data-kid=\"43\">50 hr burn</span>\n      <span style=\"font-family:var(--font-sans);font-size:9px;text-transform:uppercase;letter-spacing:.15em;color:rgba(240,235,227,0.38);font-weight:600;\" data-kid=\"44\">Numbered vessel</span>\n      <span style=\"font-family:var(--font-sans);font-size:9px;text-transform:uppercase;letter-spacing:.15em;color:rgba(240,235,227,0.38);font-weight:600;\" data-kid=\"45\">Micro-batch cured</span>\n    </div>\n\n    \n    <div style=\"margin-top:32px;\" data-kid=\"46\">\n      <button class=\"cta-btn\" data-kid=\"47\">Add to the Ritual</button>\n      <div style=\"margin-top:10px;display:flex;justify-content:space-between;align-items:center;\" data-kid=\"48\">\n        <a href=\"#\" style=\"font-family:var(--font-sans);font-size:12px;color:rgba(240,235,227,0.40);text-decoration:none;transition:color 150ms;\" onmouseover=\"this.style.color='rgba(221,125,82,1)'\" onmouseout=\"this.style.color='rgba(240,235,227,0.40)'\" data-kid=\"49\">View on Etsy →</a>\n        <span style=\"font-family:var(--font-mono);font-size:10px;color:var(--ember);letter-spacing:.05em;\" data-kid=\"50\">14 of 47 remaining</span>\n      </div>\n    </div>\n\n    <p style=\"font-family:var(--font-editorial);font-style:italic;font-size:12px;color:rgba(218,203,184,0.35);margin:20px 0 0 0;line-height:1.6;\" data-kid=\"51\">Hand-poured in the studio. Not a product — a practice.</p>\n  </div>\n</section>\n\n\n<section style=\"background:var(--vellum);display:grid;grid-template-columns:1fr 1fr;\" data-kid=\"52\">\n  \n  <div style=\"background:var(--obsidian);padding:80px 64px;display:flex;flex-direction:column;justify-content:center;\" data-kid=\"53\">\n    <p style=\"font-family:var(--font-sans);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.3em;color:rgba(168,80,43,0.8);margin:0 0 28px 0;\" data-kid=\"54\">The Ritual</p>\n    <blockquote style=\"font-family:var(--font-display);font-optical-sizing:auto;font-style:italic;font-weight:300;font-size:30px;line-height:1.4;letter-spacing:-0.01em;color:var(--cream);margin:0 0 28px 0;\" data-kid=\"55\">\"A softly salty sea breeze meets sun-warmed sand at the threshold of dusk.\"</blockquote>\n    <div style=\"width:40px;height:1px;background:rgba(218,203,184,0.22);margin-bottom:24px;\" data-kid=\"56\"></div>\n    <p style=\"font-family:var(--font-sans);font-size:14px;font-weight:300;line-height:1.75;color:rgba(240,235,227,0.56);margin:0;\" data-kid=\"57\">Capturing the raw, mineral breath of the Pacific — bonded at precisely 185°F with a soy &amp; beeswax blend for a clean, even burn. Each vessel is numbered. Each batch is finite. This is not a product — it is a practice.</p>\n  </div>\n  \n  <div style=\"padding:80px 64px;display:flex;flex-direction:column;justify-content:center;background:var(--ash);\" data-kid=\"58\">\n    <p style=\"font-family:var(--font-sans);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.3em;color:var(--ember);margin:0 0 32px 0;\" data-kid=\"59\">Craft Details</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:0;\" data-kid=\"60\">\n      <div style=\"padding:14px 0;border-bottom:1px solid rgba(218,203,184,0.5);\" data-kid=\"61\">\n        <div style=\"font-family:var(--font-sans);font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.18em;color:var(--sage);margin-bottom:6px;\" data-kid=\"62\">Wax</div>\n        <div style=\"font-family:var(--font-display);font-optical-sizing:auto;font-style:italic;font-size:16px;color:var(--obsidian);\" data-kid=\"63\">Soy &amp; beeswax</div>\n      </div>\n      <div style=\"padding:14px 0 14px 24px;border-bottom:1px solid rgba(218,203,184,0.5);\" data-kid=\"64\">\n        <div style=\"font-family:var(--font-sans);font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.18em;color:var(--sage);margin-bottom:6px;\" data-kid=\"65\">Pour temp</div>\n        <div style=\"font-family:var(--font-mono);font-size:14px;color:var(--obsidian);\" data-kid=\"66\">185°F</div>\n      </div>\n      <div style=\"padding:14px 0;border-bottom:1px solid rgba(218,203,184,0.5);\" data-kid=\"67\">\n        <div style=\"font-family:var(--font-sans);font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.18em;color:var(--sage);margin-bottom:6px;\" data-kid=\"68\">Burn time</div>\n        <div style=\"font-family:var(--font-mono);font-size:14px;color:var(--obsidian);\" data-kid=\"69\">~50 hours</div>\n      </div>\n      <div style=\"padding:14px 0 14px 24px;border-bottom:1px solid rgba(218,203,184,0.5);\" data-kid=\"70\">\n        <div style=\"font-family:var(--font-sans);font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.18em;color:var(--sage);margin-bottom:6px;\" data-kid=\"71\">Batch size</div>\n        <div style=\"font-family:var(--font-mono);font-size:14px;color:var(--obsidian);\" data-kid=\"72\">47 units</div>\n      </div>\n      <div style=\"padding:14px 0;\" data-kid=\"73\">\n        <div style=\"font-family:var(--font-sans);font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.18em;color:var(--sage);margin-bottom:6px;\" data-kid=\"74\">Weight</div>\n        <div style=\"font-family:var(--font-mono);font-size:14px;color:var(--obsidian);\" data-kid=\"75\">15 oz</div>\n      </div>\n      <div style=\"padding:14px 0 14px 24px;\" data-kid=\"76\">\n        <div style=\"font-family:var(--font-sans);font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.18em;color:var(--sage);margin-bottom:6px;\" data-kid=\"77\">Vessel</div>\n        <div style=\"font-family:var(--font-display);font-optical-sizing:auto;font-style:italic;font-size:16px;color:var(--obsidian);\" data-kid=\"78\">Numbered stoneware</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section style=\"background:var(--vellum);padding:96px 0;\" data-kid=\"79\">\n  <div style=\"max-width:1280px;margin:0 auto;padding:0 40px;\" data-kid=\"80\">\n    <div style=\"display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;\" data-kid=\"81\">\n      <div data-kid=\"82\">\n        <p style=\"font-family:var(--font-sans);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.3em;color:var(--ember);margin:0 0 10px 0;\" data-kid=\"83\">You May Also Love</p>\n        <h3 style=\"font-family:var(--font-display);font-optical-sizing:auto;font-style:italic;font-weight:400;font-size:32px;line-height:1.15;color:var(--obsidian);margin:0;\" data-kid=\"84\">From the current batch.</h3>\n      </div>\n      <a href=\"#\" style=\"font-family:var(--font-sans);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.2em;color:var(--sage);text-decoration:none;transition:color 150ms;white-space:nowrap;\" onmouseover=\"this.style.color='#a8502b'\" onmouseout=\"this.style.color='#5f6459'\" data-kid=\"85\">View All →</a>\n    </div>\n\n    \n    <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:2px;\" data-kid=\"86\">\n\n      <div class=\"related-card\" style=\"position:relative;aspect-ratio:3/4;overflow:hidden;cursor:pointer;\" data-kid=\"87\">\n        <img src=\"/api/local/images/Candera Design System/assets/images/meadowlight-botanical.jpg\" alt=\"Meadowlight Botanical\" decoding=\"async\" loading=\"lazy\" class=\"related-img\" style=\"width:100%;height:100%;object-fit:cover;display:block;\" data-kid=\"88\">\n        <div style=\"position:absolute;inset:0;background:linear-gradient(to top,rgba(20,20,18,0.80) 0%,rgba(20,20,18,0) 52%);\" data-kid=\"89\"></div>\n        <span style=\"position:absolute;top:14px;right:14px;background:#fff;color:var(--obsidian);font-family:var(--font-sans);font-size:8px;font-weight:700;text-transform:uppercase;letter-spacing:.2em;padding:3px 8px;\" data-kid=\"90\">New Release</span>\n        <span style=\"position:absolute;top:14px;left:14px;font-family:var(--font-mono);font-size:8px;color:rgba(240,235,227,0.50);letter-spacing:.1em;\" data-kid=\"91\">Batch 002</span>\n        <div style=\"position:absolute;bottom:0;left:0;right:0;padding:20px 20px 22px;\" data-kid=\"92\">\n          <div style=\"display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:8px;\" data-kid=\"93\">\n            <h4 style=\"font-family:var(--font-display);font-optical-sizing:auto;font-style:italic;font-weight:400;font-size:20px;color:#fff;margin:0;line-height:1.1;\" data-kid=\"94\">Meadowlight Botanical</h4>\n            <span style=\"font-family:var(--font-mono);font-size:14px;color:rgba(240,235,227,0.85);white-space:nowrap;margin-left:8px;\" data-kid=\"95\">$34</span>\n          </div>\n          <a href=\"#\" style=\"font-family:var(--font-sans);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.2em;color:rgba(240,235,227,0.50);text-decoration:none;transition:color 150ms;\" onmouseover=\"this.style.color='rgba(221,125,82,1)'\" onmouseout=\"this.style.color='rgba(240,235,227,0.50)'\" data-kid=\"96\">View details →</a>\n        </div>\n      </div>\n\n      <div class=\"related-card\" style=\"position:relative;aspect-ratio:3/4;overflow:hidden;cursor:pointer;\" data-kid=\"97\">\n        <img src=\"/api/local/images/Candera Design System/assets/images/crimson-noir.jpg\" alt=\"Crimson Noir\" decoding=\"async\" loading=\"lazy\" class=\"related-img\" style=\"width:100%;height:100%;object-fit:cover;display:block;\" data-kid=\"98\">\n        <div style=\"position:absolute;inset:0;background:linear-gradient(to top,rgba(20,20,18,0.80) 0%,rgba(20,20,18,0) 52%);\" data-kid=\"99\"></div>\n        <span style=\"position:absolute;top:14px;right:14px;background:#fff;color:var(--obsidian);font-family:var(--font-sans);font-size:8px;font-weight:700;text-transform:uppercase;letter-spacing:.2em;padding:3px 8px;\" data-kid=\"100\">Limited Batch</span>\n        <span style=\"position:absolute;top:14px;left:14px;font-family:var(--font-mono);font-size:8px;color:rgba(240,235,227,0.50);letter-spacing:.1em;\" data-kid=\"101\">Batch 003</span>\n        <div style=\"position:absolute;bottom:0;left:0;right:0;padding:20px 20px 22px;\" data-kid=\"102\">\n          <div style=\"display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:8px;\" data-kid=\"103\">\n            <h4 style=\"font-family:var(--font-display);font-optical-sizing:auto;font-style:italic;font-weight:400;font-size:20px;color:#fff;margin:0;line-height:1.1;\" data-kid=\"104\">Crimson Noir</h4>\n            <span style=\"font-family:var(--font-mono);font-size:14px;color:rgba(240,235,227,0.85);white-space:nowrap;margin-left:8px;\" data-kid=\"105\">$42</span>\n          </div>\n          <a href=\"#\" style=\"font-family:var(--font-sans);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.2em;color:rgba(240,235,227,0.50);text-decoration:none;transition:color 150ms;\" onmouseover=\"this.style.color='rgba(221,125,82,1)'\" onmouseout=\"this.style.color='rgba(240,235,227,0.50)'\" data-kid=\"106\">View details →</a>\n        </div>\n      </div>\n\n      <div class=\"related-card\" style=\"position:relative;aspect-ratio:3/4;overflow:hidden;cursor:pointer;\" data-kid=\"107\">\n        <img src=\"/api/local/images/Candera Design System/assets/images/ever-after-glow.jpg\" alt=\"Ever After Glow\" decoding=\"async\" loading=\"lazy\" class=\"related-img\" style=\"width:100%;height:100%;object-fit:cover;display:block;\" data-kid=\"108\">\n        <div style=\"position:absolute;inset:0;background:linear-gradient(to top,rgba(20,20,18,0.80) 0%,rgba(20,20,18,0) 52%);\" data-kid=\"109\"></div>\n        <span style=\"position:absolute;top:14px;right:14px;background:#fff;color:var(--obsidian);font-family:var(--font-sans);font-size:8px;font-weight:700;text-transform:uppercase;letter-spacing:.2em;padding:3px 8px;\" data-kid=\"110\">Bestseller</span>\n        <span style=\"position:absolute;top:14px;left:14px;font-family:var(--font-mono);font-size:8px;color:rgba(240,235,227,0.50);letter-spacing:.1em;\" data-kid=\"111\">Batch 004</span>\n        <div style=\"position:absolute;bottom:0;left:0;right:0;padding:20px 20px 22px;\" data-kid=\"112\">\n          <div style=\"display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:8px;\" data-kid=\"113\">\n            <h4 style=\"font-family:var(--font-display);font-optical-sizing:auto;font-style:italic;font-weight:400;font-size:20px;color:#fff;margin:0;line-height:1.1;\" data-kid=\"114\">Ever After Glow</h4>\n            <span style=\"font-family:var(--font-mono);font-size:14px;color:rgba(240,235,227,0.85);white-space:nowrap;margin-left:8px;\" data-kid=\"115\">$34</span>\n          </div>\n          <a href=\"#\" style=\"font-family:var(--font-sans);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.2em;color:rgba(240,235,227,0.50);text-decoration:none;transition:color 150ms;\" onmouseover=\"this.style.color='rgba(221,125,82,1)'\" onmouseout=\"this.style.color='rgba(240,235,227,0.50)'\" data-kid=\"116\">View details →</a>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n\n<section style=\"background:var(--obsidian);padding:80px 0;\" data-kid=\"117\">\n  <div style=\"max-width:560px;margin:0 auto;padding:0 40px;text-align:center;\" data-kid=\"118\">\n    <p style=\"font-family:var(--font-sans);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.3em;color:var(--rose);margin:0 0 16px 0;\" data-kid=\"119\">The Inner Circle</p>\n    <h2 style=\"font-family:var(--font-display);font-optical-sizing:auto;font-style:italic;font-weight:400;font-size:36px;line-height:1.1;color:#fff;margin:0 0 16px 0;\" data-kid=\"120\">Join the Inner Circle.</h2>\n    <p style=\"font-family:var(--font-sans);font-size:14px;font-weight:300;line-height:1.7;color:rgba(255,255,255,0.55);margin:0 0 32px 0;\" data-kid=\"121\">Our batches often sell out in days. Join our list to receive early access to new scent drops and personal ritual invitations.</p>\n    <div style=\"display:flex;gap:0;align-items:stretch;\" data-kid=\"122\">\n      <input type=\"email\" placeholder=\"your@email.com\" style=\"flex:1;background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.25);color:#fff;font-family:var(--font-sans);font-size:14px;font-weight:300;padding:12px 0;outline:none;min-width:0;caret-color:var(--rose);\" data-kid=\"123\">\n      <button class=\"ic-btn\" data-kid=\"124\">Request Entry</button>\n    </div>\n    <p style=\"font-family:var(--font-editorial);font-style:italic;font-size:12px;color:rgba(255,255,255,0.28);margin:14px 0 0 0;\" data-kid=\"125\">This is not a newsletter. It is a correspondence.</p>\n  </div>\n</section>\n\n\n<footer style=\"background:var(--linen);padding:72px 0 44px;border-top:1px solid rgba(218,203,184,0.4);\" data-kid=\"126\">\n  <div style=\"max-width:1280px;margin:0 auto;padding:0 40px;\" data-kid=\"127\">\n    <div style=\"display:grid;grid-template-columns:2fr 1fr 1fr;gap:48px;padding-bottom:40px;border-bottom:1px solid rgba(218,203,184,0.4);\" data-kid=\"128\">\n      <div data-kid=\"129\">\n        <a href=\"#\" style=\"font-family:var(--font-display);font-weight:700;font-size:20px;letter-spacing:-0.02em;color:var(--obsidian);text-decoration:none;display:block;margin-bottom:10px;\" data-kid=\"130\">CANDERA</a>\n        <p style=\"font-family:var(--font-editorial);font-style:italic;font-size:14px;color:var(--sage);margin:0 0 20px 0;max-width:280px;line-height:1.7;\" data-kid=\"131\">Cultivating intentional living through scent and micro-batch artisanry. Based in the studio, shared everywhere.</p>\n        <div style=\"display:flex;gap:16px;align-items:center;\" data-kid=\"132\">\n          <a href=\"#\" class=\"c-social-link\" style=\"color:var(--sage);transition:color 150ms;display:inline-flex;\" data-kid=\"133\"><i data-lucide=\"camera\" style=\"width:18px;height:18px;stroke-width:1.5;\" data-kid=\"134\"></i></a>\n          <a href=\"#\" class=\"c-social-link\" style=\"color:var(--sage);transition:color 150ms;display:inline-flex;\" data-kid=\"135\"><i data-lucide=\"message-square\" style=\"width:18px;height:18px;stroke-width:1.5;\" data-kid=\"136\"></i></a>\n          <a href=\"#\" class=\"c-social-link\" style=\"color:var(--sage);transition:color 150ms;display:inline-flex;\" data-kid=\"137\"><i data-lucide=\"globe\" style=\"width:18px;height:18px;stroke-width:1.5;\" data-kid=\"138\"></i></a>\n        </div>\n      </div>\n      <div data-kid=\"139\">\n        <h5 style=\"font-family:var(--font-sans);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.25em;color:var(--sage);margin:0 0 18px 0;\" data-kid=\"140\">Navigation</h5>\n        <ul style=\"list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px;\" data-kid=\"141\">\n          <li data-kid=\"142\"><a href=\"#\" class=\"c-footer-link\" style=\"font-family:var(--font-sans);font-size:13px;font-weight:300;color:var(--obsidian);text-decoration:none;transition:color 150ms;\" data-kid=\"143\">Current Batch</a></li>\n          <li data-kid=\"144\"><a href=\"#\" class=\"c-footer-link\" style=\"font-family:var(--font-sans);font-size:13px;font-weight:300;color:var(--obsidian);text-decoration:none;transition:color 150ms;\" data-kid=\"145\">The Craft</a></li>\n          <li data-kid=\"146\"><a href=\"#\" class=\"c-footer-link\" style=\"font-family:var(--font-sans);font-size:13px;font-weight:300;color:var(--obsidian);text-decoration:none;transition:color 150ms;\" data-kid=\"147\">Inner Circle</a></li>\n          <li data-kid=\"148\"><a href=\"#\" class=\"c-footer-link\" style=\"font-family:var(--font-sans);font-size:13px;font-weight:300;color:var(--obsidian);text-decoration:none;transition:color 150ms;display:inline-flex;align-items:center;gap:4px;\" data-kid=\"149\">View All on Etsy <span style=\"font-size:11px;\" data-kid=\"150\">↗</span></a></li>\n        </ul>\n      </div>\n      <div data-kid=\"151\">\n        <h5 style=\"font-family:var(--font-sans);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.25em;color:var(--sage);margin:0 0 18px 0;\" data-kid=\"152\">Assistance</h5>\n        <ul style=\"list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px;\" data-kid=\"153\">\n          <li data-kid=\"154\"><span style=\"font-family:var(--font-sans);font-size:13px;font-weight:300;color:var(--sage);\" data-kid=\"155\">Shipping &amp; Returns</span></li>\n          <li data-kid=\"156\"><span style=\"font-family:var(--font-sans);font-size:13px;font-weight:300;color:var(--sage);\" data-kid=\"157\">Wholesale</span></li>\n          <li data-kid=\"158\"><a href=\"#\" class=\"c-footer-link\" style=\"font-family:var(--font-sans);font-size:13px;font-weight:300;color:var(--obsidian);text-decoration:none;transition:color 150ms;\" data-kid=\"159\">Contact</a></li>\n        </ul>\n      </div>\n    </div>\n    <div style=\"display:flex;justify-content:space-between;align-items:center;padding-top:22px;\" data-kid=\"160\">\n      <p style=\"font-family:var(--font-sans);font-size:12px;font-weight:300;color:var(--sage);margin:0;\" data-kid=\"161\">© 2026 Candera Studio. All rights reserved.</p>\n      <div style=\"display:flex;gap:20px;\" data-kid=\"162\">\n        <span style=\"font-family:var(--font-sans);font-size:12px;font-weight:300;color:var(--sage);cursor:pointer;\" data-kid=\"163\">Privacy Policy</span>\n        <span style=\"font-family:var(--font-sans);font-size:12px;font-weight:300;color:var(--sage);cursor:pointer;\" data-kid=\"164\">Terms of Service</span>\n      </div>\n    </div>\n  </div>\n</footer>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"165\"></script>\n<script data-kid=\"166\">if (typeof lucide !== 'undefined') { lucide.createIcons(); }</script>\n",
