      "html": "\n<style data-kid=\"0\">\n  /* EB Garamond — not in theme fonts list, import manually */\n  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;1,400&display=swap');\n\n  .font-display { font-family: var(--k-font-family-heading); }\n  .font-editorial { font-family: 'EB Garamond', Georgia, serif; }\n  .font-sans { font-family: var(--k-font-family-body); }\n\n  .hero-bg {\n    background-image: url('/api/local/images/Candera Design System/assets/images/seashell-garden.jpg');\n    background-size: cover;\n    background-position: center;\n  }\n  .grain-overlay {\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E\");\n    opacity: 0.04;\n    mix-blend-mode: overlay;\n  }\n  .nav-link {\n    font-family: var(--k-font-family-body);\n    font-size: var(--k-font-size-sm);\n    font-weight: var(--k-font-weight-semibold);\n    text-transform: uppercase;\n    letter-spacing: 0.2em;\n    color: var(--k-color-text-secondary);\n    text-decoration: none;\n    transition: color 150ms;\n  }\n  .nav-link:hover { color: var(--k-color-primary); }\n  .eyebrow {\n    font-family: var(--k-font-family-body);\n    font-size: var(--k-font-size-sm);\n    font-weight: var(--k-font-weight-bold);\n    text-transform: uppercase;\n    letter-spacing: 0.3em;\n    color: var(--k-color-primary-hover);\n  }\n  .section-label {\n    font-family: var(--k-font-family-body);\n    font-size: var(--k-font-size-sm);\n    font-weight: var(--k-font-weight-semibold);\n    text-transform: uppercase;\n    letter-spacing: 0.2em;\n    color: var(--k-color-text-secondary);\n  }\n  .card-cta {\n    font-family: var(--k-font-family-body);\n    font-size: var(--k-font-size-sm);\n    font-weight: var(--k-font-weight-bold);\n    text-transform: uppercase;\n    letter-spacing: 0.2em;\n    border: var(--k-border-width-default) solid var(--k-color-text-primary);\n    color: var(--k-color-text-primary);\n    background: transparent;\n    width: 100%;\n    padding: var(--k-spacing-sm);\n    cursor: pointer;\n    transition: background 200ms, color 200ms;\n  }\n  .card-cta:hover { background: var(--k-color-text-primary); color: var(--k-color-bg-page); }\n  .btn-primary {\n    font-family: var(--k-font-family-body);\n    font-size: 11px;\n    font-weight: var(--k-font-weight-bold);\n    text-transform: uppercase;\n    letter-spacing: 0.3em;\n    background: var(--k-color-primary);\n    color: #fff;\n    padding: var(--k-spacing-md) 32px;\n    border: none;\n    cursor: pointer;\n    transition: background 150ms;\n    text-decoration: none;\n    display: inline-block;\n  }\n  .btn-primary:hover { background: var(--k-color-primary-hover); }\n</style>\n\n\n<div style=\"background: rgba(253,251,247,0.97); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(218,204,184,0.35); position: relative; z-index: 50;\" data-kid=\"1\">\n  <div style=\"max-width: 1280px; margin: 0 auto; padding: 0 var(--k-spacing-xl); display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; height: 64px;\" data-kid=\"2\">\n    <div data-kid=\"3\"></div>\n    <a href=\"#\" style=\"font-family: var(--k-font-family-heading); font-weight: var(--k-font-weight-bold); font-size: 22px; letter-spacing: -0.02em; color: var(--k-color-text-primary); text-decoration: none; justify-self: center;\" data-kid=\"4\">CANDERA</a>\n    <div style=\"display: flex; align-items: center; gap: var(--k-spacing-lg); justify-self: end;\" data-kid=\"5\">\n      <a href=\"#\" class=\"nav-link\" data-kid=\"6\">Collection</a>\n      <span style=\"color: var(--k-color-border); font-size: 12px;\" aria-hidden=\"true\" data-kid=\"7\">|</span>\n      <a href=\"#\" class=\"nav-link\" data-kid=\"8\">The Craft</a>\n      <span style=\"color: var(--k-color-border); font-size: 12px;\" aria-hidden=\"true\" data-kid=\"9\">|</span>\n      <a href=\"#\" class=\"nav-link\" data-kid=\"10\">Scent Quiz</a>\n      <a href=\"#\" aria-label=\"Search\" style=\"color: var(--k-color-text-secondary); display: inline-flex; align-items: center; transition: color 150ms;\" onmouseover=\"this.style.color='var(--k-color-primary)'\" onmouseout=\"this.style.color='var(--k-color-text-secondary)'\" data-kid=\"11\">\n        <i data-lucide=\"search\" aria-hidden=\"true\" style=\"width: 16px; height: 16px; stroke-width: 1.5;\" data-kid=\"12\"></i>\n      </a>\n      <a href=\"#\" aria-label=\"Shopping bag\" style=\"color: var(--k-color-text-secondary); display: inline-flex; align-items: center; transition: color 150ms;\" onmouseover=\"this.style.color='var(--k-color-primary)'\" onmouseout=\"this.style.color='var(--k-color-text-secondary)'\" data-kid=\"13\">\n        <i data-lucide=\"shopping-bag\" aria-hidden=\"true\" style=\"width: 18px; height: 18px; stroke-width: 1.5;\" data-kid=\"14\"></i>\n      </a>\n    </div>\n  </div>\n</div>\n\n\n<div class=\"hero-bg\" style=\"height: 720px; position: relative; overflow: hidden; display: flex; align-items: flex-end;\" data-kid=\"15\">\n  <div style=\"position: absolute; inset: 0; background: rgba(0,0,0,0.55);\" data-kid=\"16\"></div>\n  <div class=\"grain-overlay\" style=\"position: absolute; inset: 0;\" aria-hidden=\"true\" data-kid=\"17\"></div>\n  <div style=\"position: relative; z-index: 10; max-width: 680px; padding: 0 80px 80px 80px;\" data-kid=\"18\">\n    <p class=\"eyebrow\" style=\"margin-bottom: var(--k-spacing-xl); color: var(--k-color-primary);\" data-kid=\"19\">Hand-Poured in the Studio</p>\n    <h1 style=\"font-family: var(--k-font-family-heading); font-style: italic; font-weight: var(--k-font-weight-medium); font-size: clamp(56px, 6vw, 88px); line-height: 1.05; letter-spacing: -0.01em; color: #fff; margin: 0 0 var(--k-spacing-xl) 0; font-optical-sizing: auto;\" data-kid=\"20\">An invitation<br data-kid=\"21\">to slow down.</h1>\n    <p style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-lg); font-weight: var(--k-font-weight-normal); color: rgba(255,255,255,0.70); margin: 0 0 36px 0; line-height: 1.6;\" data-kid=\"22\">Limited Release: Batch 014 now curing in the studio.</p>\n    <div style=\"display: flex; align-items: center; gap: 28px; flex-wrap: wrap;\" data-kid=\"23\">\n      <a href=\"#\" class=\"btn-primary\" data-kid=\"24\">Explore the Collection</a>\n      <a href=\"#\" style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-base); color: rgba(255,255,255,0.70); text-decoration: none; letter-spacing: 0.05em; transition: color 150ms;\" onmouseover=\"this.style.color='rgba(255,255,255,1)'\" onmouseout=\"this.style.color='rgba(255,255,255,0.70)'\" data-kid=\"25\">Take the Scent Quiz →</a>\n    </div>\n  </div>\n</div>\n\n\n<div style=\"background: var(--k-color-bg-surface); padding: var(--k-spacing-3xl) 0;\" data-kid=\"26\">\n  <div style=\"max-width: 1280px; margin: 0 auto; padding: 0 var(--k-spacing-xl);\" data-kid=\"27\">\n    <div style=\"margin-bottom: var(--k-spacing-2xl);\" data-kid=\"28\">\n      <p class=\"eyebrow\" style=\"margin-bottom: 14px;\" data-kid=\"29\">The Current Batch</p>\n      <h2 style=\"font-family: var(--k-font-family-heading); font-style: italic; font-weight: var(--k-font-weight-medium); font-size: var(--k-font-size-4xl); line-height: 1.1; letter-spacing: -0.01em; color: var(--k-color-text-primary); margin: 0 0 var(--k-spacing-md) 0; font-optical-sizing: auto;\" data-kid=\"30\">Rooted in Earth, Released in Air.</h2>\n      <p style=\"font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: 17px; color: var(--k-color-text-secondary); line-height: 1.7; max-width: 560px; margin: 0;\" data-kid=\"31\">Each vessel is part of a numbered micro-batch, hand-labeled and inspected for peak botanical clarity.</p>\n    </div>\n    <div style=\"display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--k-spacing-2xl);\" data-kid=\"32\">\n\n      \n      <div style=\"background: #fff; box-shadow: var(--k-shadow-sm);\" data-kid=\"33\">\n        <div style=\"position: relative; aspect-ratio: 4/5; overflow: hidden;\" data-kid=\"34\">\n          <img src=\"/api/local/images/Candera Design System/assets/images/seashell-garden.jpg\" alt=\"Seashell Garden Glow\" decoding=\"async\" loading=\"lazy\" style=\"width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 2s cubic-bezier(0.4,0,0.2,1);\" onmouseover=\"this.style.transform='scale(1.07)'\" onmouseout=\"this.style.transform='scale(1)'\" data-kid=\"35\">\n          <div style=\"position: absolute; top: var(--k-spacing-sm); left: var(--k-spacing-sm); background: #fff; color: var(--k-color-text-primary); font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-bold); text-transform: uppercase; letter-spacing: 0.15em; padding: 3px var(--k-spacing-xs); border-radius: var(--k-radius-sm);\" data-kid=\"36\">Bestseller</div>\n          <div style=\"position: absolute; top: var(--k-spacing-sm); right: var(--k-spacing-sm); color: rgba(255,255,255,0.80); font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: 500; letter-spacing: 0.12em;\" data-kid=\"37\">Batch 001</div>\n        </div>\n        <div style=\"padding: var(--k-spacing-md); border-top: var(--k-border-width-default) solid var(--k-color-border);\" data-kid=\"38\">\n          <div style=\"display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid rgba(218,204,184,0.40); padding-bottom: var(--k-spacing-sm); margin-bottom: var(--k-spacing-sm);\" data-kid=\"39\">\n            <a href=\"#\" style=\"text-decoration: none;\" onmouseover=\"this.querySelector('h3').style.color='var(--k-color-primary)'\" onmouseout=\"this.querySelector('h3').style.color='var(--k-color-text-primary)'\" data-kid=\"40\"><h3 style=\"font-family: var(--k-font-family-heading); font-style: italic; font-weight: var(--k-font-weight-medium); font-size: var(--k-font-size-2xl); line-height: 1.2; color: var(--k-color-text-primary); margin: 0; transition: color 200ms; font-optical-sizing: auto;\" data-kid=\"41\">Seashell Garden Glow</h3></a>\n            <span style=\"font-family: var(--k-font-family-body); font-size: 14px; font-weight: var(--k-font-weight-normal); font-variant-numeric: tabular-nums; color: var(--k-color-text-primary); white-space: nowrap; margin-left: var(--k-spacing-sm);\" data-kid=\"42\">$38.00</span>\n          </div>\n          <div style=\"display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--k-spacing-xs); margin-bottom: 14px;\" data-kid=\"43\">\n            <div data-kid=\"44\"><div style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.15em; color: var(--k-color-text-muted); margin-bottom: 3px;\" data-kid=\"45\">Top</div><div style=\"font-family: var(--k-font-family-body); font-size: 11px; color: var(--k-color-text-primary); font-weight: var(--k-font-weight-normal);\" data-kid=\"46\">Sea Breeze</div></div>\n            <div data-kid=\"47\"><div style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.15em; color: var(--k-color-text-muted); margin-bottom: 3px;\" data-kid=\"48\">Heart</div><div style=\"font-family: var(--k-font-family-body); font-size: 11px; color: var(--k-color-text-primary); font-weight: var(--k-font-weight-normal);\" data-kid=\"49\">Driftwood</div></div>\n            <div data-kid=\"50\"><div style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.15em; color: var(--k-color-text-muted); margin-bottom: 3px;\" data-kid=\"51\">Base</div><div style=\"font-family: var(--k-font-family-body); font-size: 11px; color: var(--k-color-text-primary); font-weight: var(--k-font-weight-normal);\" data-kid=\"52\">Salt Air</div></div>\n          </div>\n          <button class=\"card-cta\" data-kid=\"53\">Add to the Ritual</button>\n        </div>\n      </div>\n\n      \n      <div style=\"background: #fff; box-shadow: var(--k-shadow-sm);\" data-kid=\"54\">\n        <div style=\"position: relative; aspect-ratio: 4/5; overflow: hidden;\" data-kid=\"55\">\n          <img src=\"/api/local/images/Candera Design System/assets/images/meadowlight-botanical.jpg\" alt=\"Meadowlight Botanical\" decoding=\"async\" loading=\"lazy\" style=\"width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 2s cubic-bezier(0.4,0,0.2,1);\" onmouseover=\"this.style.transform='scale(1.07)'\" onmouseout=\"this.style.transform='scale(1)'\" data-kid=\"56\">\n          <div style=\"position: absolute; top: var(--k-spacing-sm); left: var(--k-spacing-sm); background: #fff; color: var(--k-color-text-primary); font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-bold); text-transform: uppercase; letter-spacing: 0.15em; padding: 3px var(--k-spacing-xs); border-radius: var(--k-radius-sm);\" data-kid=\"57\">New Release</div>\n          <div style=\"position: absolute; top: var(--k-spacing-sm); right: var(--k-spacing-sm); color: rgba(255,255,255,0.80); font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: 500; letter-spacing: 0.12em;\" data-kid=\"58\">Batch 002</div>\n        </div>\n        <div style=\"padding: var(--k-spacing-md); border-top: var(--k-border-width-default) solid var(--k-color-border);\" data-kid=\"59\">\n          <div style=\"display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid rgba(218,204,184,0.40); padding-bottom: var(--k-spacing-sm); margin-bottom: var(--k-spacing-sm);\" data-kid=\"60\">\n            <a href=\"#\" style=\"text-decoration: none;\" onmouseover=\"this.querySelector('h3').style.color='var(--k-color-primary)'\" onmouseout=\"this.querySelector('h3').style.color='var(--k-color-text-primary)'\" data-kid=\"61\"><h3 style=\"font-family: var(--k-font-family-heading); font-style: italic; font-weight: var(--k-font-weight-medium); font-size: var(--k-font-size-2xl); line-height: 1.2; color: var(--k-color-text-primary); margin: 0; transition: color 200ms; font-optical-sizing: auto;\" data-kid=\"62\">Meadowlight Botanical</h3></a>\n            <span style=\"font-family: var(--k-font-family-body); font-size: 14px; font-weight: var(--k-font-weight-normal); font-variant-numeric: tabular-nums; color: var(--k-color-text-primary); white-space: nowrap; margin-left: var(--k-spacing-sm);\" data-kid=\"63\">$38.00</span>\n          </div>\n          <div style=\"display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--k-spacing-xs); margin-bottom: 14px;\" data-kid=\"64\">\n            <div data-kid=\"65\"><div style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.15em; color: var(--k-color-text-muted); margin-bottom: 3px;\" data-kid=\"66\">Top</div><div style=\"font-family: var(--k-font-family-body); font-size: 11px; color: var(--k-color-text-primary); font-weight: var(--k-font-weight-normal);\" data-kid=\"67\">Fresh Green</div></div>\n            <div data-kid=\"68\"><div style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.15em; color: var(--k-color-text-muted); margin-bottom: 3px;\" data-kid=\"69\">Heart</div><div style=\"font-family: var(--k-font-family-body); font-size: 11px; color: var(--k-color-text-primary); font-weight: var(--k-font-weight-normal);\" data-kid=\"70\">Lily of Valley</div></div>\n            <div data-kid=\"71\"><div style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.15em; color: var(--k-color-text-muted); margin-bottom: 3px;\" data-kid=\"72\">Base</div><div style=\"font-family: var(--k-font-family-body); font-size: 11px; color: var(--k-color-text-primary); font-weight: var(--k-font-weight-normal);\" data-kid=\"73\">Morning Dew</div></div>\n          </div>\n          <button class=\"card-cta\" data-kid=\"74\">Add to the Ritual</button>\n        </div>\n      </div>\n\n      \n      <div style=\"background: #fff; box-shadow: var(--k-shadow-sm);\" data-kid=\"75\">\n        <div style=\"position: relative; aspect-ratio: 4/5; overflow: hidden;\" data-kid=\"76\">\n          <img src=\"/api/local/images/Candera Design System/assets/images/crimson-noir.jpg\" alt=\"Crimson Noir\" decoding=\"async\" loading=\"lazy\" style=\"width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 2s cubic-bezier(0.4,0,0.2,1);\" onmouseover=\"this.style.transform='scale(1.07)'\" onmouseout=\"this.style.transform='scale(1)'\" data-kid=\"77\">\n          <div style=\"position: absolute; top: var(--k-spacing-sm); left: var(--k-spacing-sm); background: #fff; color: var(--k-color-text-primary); font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-bold); text-transform: uppercase; letter-spacing: 0.15em; padding: 3px var(--k-spacing-xs); border-radius: var(--k-radius-sm);\" data-kid=\"78\">Limited Batch</div>\n          <div style=\"position: absolute; top: var(--k-spacing-sm); right: var(--k-spacing-sm); color: rgba(255,255,255,0.80); font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: 500; letter-spacing: 0.12em;\" data-kid=\"79\">Batch 003</div>\n        </div>\n        <div style=\"padding: var(--k-spacing-md); border-top: var(--k-border-width-default) solid var(--k-color-border);\" data-kid=\"80\">\n          <div style=\"display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid rgba(218,204,184,0.40); padding-bottom: var(--k-spacing-sm); margin-bottom: var(--k-spacing-sm);\" data-kid=\"81\">\n            <a href=\"#\" style=\"text-decoration: none;\" onmouseover=\"this.querySelector('h3').style.color='var(--k-color-primary)'\" onmouseout=\"this.querySelector('h3').style.color='var(--k-color-text-primary)'\" data-kid=\"82\"><h3 style=\"font-family: var(--k-font-family-heading); font-style: italic; font-weight: var(--k-font-weight-medium); font-size: var(--k-font-size-2xl); line-height: 1.2; color: var(--k-color-text-primary); margin: 0; transition: color 200ms; font-optical-sizing: auto;\" data-kid=\"83\">Crimson Noir</h3></a>\n            <span style=\"font-family: var(--k-font-family-body); font-size: 14px; font-weight: var(--k-font-weight-normal); font-variant-numeric: tabular-nums; color: var(--k-color-text-primary); white-space: nowrap; margin-left: var(--k-spacing-sm);\" data-kid=\"84\">$38.00</span>\n          </div>\n          <div style=\"display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--k-spacing-xs); margin-bottom: 14px;\" data-kid=\"85\">\n            <div data-kid=\"86\"><div style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.15em; color: var(--k-color-text-muted); margin-bottom: 3px;\" data-kid=\"87\">Top</div><div style=\"font-family: var(--k-font-family-body); font-size: 11px; color: var(--k-color-text-primary); font-weight: var(--k-font-weight-normal);\" data-kid=\"88\">Dark Berry</div></div>\n            <div data-kid=\"89\"><div style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.15em; color: var(--k-color-text-muted); margin-bottom: 3px;\" data-kid=\"90\">Heart</div><div style=\"font-family: var(--k-font-family-body); font-size: 11px; color: var(--k-color-text-primary); font-weight: var(--k-font-weight-normal);\" data-kid=\"91\">Merlot</div></div>\n            <div data-kid=\"92\"><div style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.15em; color: var(--k-color-text-muted); margin-bottom: 3px;\" data-kid=\"93\">Base</div><div style=\"font-family: var(--k-font-family-body); font-size: 11px; color: var(--k-color-text-primary); font-weight: var(--k-font-weight-normal);\" data-kid=\"94\">Vetiver</div></div>\n          </div>\n          <button class=\"card-cta\" data-kid=\"95\">Add to the Ritual</button>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n\n<div style=\"background: var(--k-color-bg-surface-hover); padding: 96px 0;\" data-kid=\"96\">\n  <div style=\"max-width: 1280px; margin: 0 auto; padding: 0 var(--k-spacing-xl);\" data-kid=\"97\">\n    <p class=\"eyebrow\" style=\"text-align: center; margin-bottom: 56px;\" data-kid=\"98\">Voices of the Inner Circle</p>\n    <div style=\"display: grid; grid-template-columns: repeat(3, 1fr); gap: 48px;\" data-kid=\"99\">\n      <div data-kid=\"100\">\n        <p style=\"font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: var(--k-font-size-xl); line-height: 1.65; color: var(--k-color-text-primary); margin: 0 0 var(--k-spacing-md) 0;\" data-kid=\"101\">\"The scent profile is unlike anything mass-produced. It fills the room without overwhelming the senses.\"</p>\n        <p style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-base); font-weight: var(--k-font-weight-normal); color: var(--k-color-text-secondary); margin: 0 0 var(--k-spacing-sm) 0;\" data-kid=\"102\">— Elena R., Los Angeles</p>\n        <span style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.2em; background: rgba(255,255,255,0.6); color: var(--k-color-text-secondary); padding: 3px var(--k-spacing-xs); border-radius: var(--k-radius-sm);\" data-kid=\"103\">Verified Ritualist</span>\n      </div>\n      <div data-kid=\"104\">\n        <p style=\"font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: var(--k-font-size-xl); line-height: 1.65; color: var(--k-color-text-primary); margin: 0 0 var(--k-spacing-md) 0;\" data-kid=\"105\">\"I reuse the stoneware vessels for my succulents. They are truly objects of art, even after the burn.\"</p>\n        <p style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-base); font-weight: var(--k-font-weight-normal); color: var(--k-color-text-secondary); margin: 0 0 var(--k-spacing-sm) 0;\" data-kid=\"106\">— James T., Austin</p>\n        <span style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.2em; background: rgba(255,255,255,0.6); color: var(--k-color-text-secondary); padding: 3px var(--k-spacing-xs); border-radius: var(--k-radius-sm);\" data-kid=\"107\">Repeat Collector</span>\n      </div>\n      <div data-kid=\"108\">\n        <p style=\"font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: var(--k-font-size-xl); line-height: 1.65; color: var(--k-color-text-primary); margin: 0 0 var(--k-spacing-md) 0;\" data-kid=\"109\">\"A ritual I look forward to every evening. This is the soul of my living room.\"</p>\n        <p style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-base); font-weight: var(--k-font-weight-normal); color: var(--k-color-text-secondary); margin: 0 0 var(--k-spacing-sm) 0;\" data-kid=\"110\">— Sarah L., Brooklyn</p>\n        <span style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-xs); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.2em; background: rgba(255,255,255,0.6); color: var(--k-color-text-secondary); padding: 3px var(--k-spacing-xs); border-radius: var(--k-radius-sm);\" data-kid=\"111\">Verified Ritualist</span>\n      </div>\n    </div>\n  </div>\n</div>\n\n\n<div style=\"background: var(--k-color-accent); padding: var(--k-spacing-3xl) 0;\" data-kid=\"112\">\n  <div style=\"max-width: 1280px; margin: 0 auto; padding: 0 var(--k-spacing-xl); text-align: center;\" data-kid=\"113\">\n    <p style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-sm); font-weight: var(--k-font-weight-bold); text-transform: uppercase; letter-spacing: 0.3em; color: var(--k-color-secondary); margin: 0 0 var(--k-spacing-md) 0;\" data-kid=\"114\">The Inner Circle</p>\n    <h2 style=\"font-family: var(--k-font-family-heading); font-style: italic; font-weight: var(--k-font-weight-medium); font-size: var(--k-font-size-3xl); line-height: 1.15; letter-spacing: -0.01em; color: #fff; margin: 0 0 var(--k-spacing-xl) 0; font-optical-sizing: auto;\" data-kid=\"115\">Join the Inner Circle.</h2>\n    <p style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-lg); font-weight: var(--k-font-weight-normal); color: rgba(255,255,255,0.68); line-height: 1.75; max-width: 480px; margin: 0 auto 40px auto;\" data-kid=\"116\">Our batches often sell out in days. Join our list to receive early access to new scent drops and personal ritual invitations.</p>\n    <div style=\"max-width: 400px; margin: 0 auto var(--k-spacing-md) auto; display: flex; border-bottom: var(--k-border-width-default) solid rgba(255,255,255,0.30);\" data-kid=\"117\">\n      <input type=\"email\" placeholder=\"Your email address\" style=\"flex: 1; background: transparent; border: none; outline: none; font-family: var(--k-font-family-body); font-size: var(--k-font-size-base); font-weight: var(--k-font-weight-normal); color: #fff; padding: var(--k-spacing-sm) 0; caret-color: var(--k-color-secondary);\" data-kid=\"118\">\n      <button style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-sm); font-weight: var(--k-font-weight-bold); text-transform: uppercase; letter-spacing: 0.25em; background: var(--k-color-secondary); color: #fff; border: none; padding: var(--k-spacing-sm) var(--k-spacing-xl); cursor: pointer; white-space: nowrap; transition: background 150ms;\" onmouseover=\"this.style.background='#8a5e72'\" onmouseout=\"this.style.background='var(--k-color-secondary)'\" data-kid=\"119\">Request Entry</button>\n    </div>\n    <p style=\"font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: var(--k-font-size-base); color: rgba(255,255,255,0.38); margin: 0;\" data-kid=\"120\">This is not a newsletter. It is a correspondence.</p>\n  </div>\n</div>\n\n\n<footer style=\"background: var(--k-color-bg-page); padding: 80px 0 48px 0; border-top: var(--k-border-width-default) solid rgba(218,204,184,0.45);\" data-kid=\"121\">\n  <div style=\"max-width: 1280px; margin: 0 auto; padding: 0 var(--k-spacing-xl);\" data-kid=\"122\">\n    <div style=\"display: grid; grid-template-columns: 2fr 1fr 1fr; gap: var(--k-spacing-2xl);\" data-kid=\"123\">\n      <div data-kid=\"124\">\n        <a href=\"#\" style=\"font-family: var(--k-font-family-heading); font-weight: var(--k-font-weight-bold); font-size: var(--k-font-size-2xl); letter-spacing: -0.02em; color: var(--k-color-text-primary); text-decoration: none; display: block; margin-bottom: var(--k-spacing-sm);\" data-kid=\"125\">CANDERA</a>\n        <p style=\"font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: var(--k-font-size-base); color: var(--k-color-text-muted); line-height: 1.7; margin: 0 0 var(--k-spacing-lg) 0; max-width: 280px;\" data-kid=\"126\">Cultivating intentional living through scent and micro-batch artisanry. Based in the studio, shared everywhere.</p>\n        <div style=\"display: flex; gap: var(--k-spacing-md);\" data-kid=\"127\">\n          <a href=\"#\" style=\"color: var(--k-color-text-muted); display: inline-flex; transition: color 150ms;\" onmouseover=\"this.style.color='var(--k-color-primary)'\" onmouseout=\"this.style.color='var(--k-color-text-muted)'\" data-kid=\"128\"><i data-lucide=\"camera\" style=\"width: 18px; height: 18px; stroke-width: 1.5;\" data-kid=\"129\"></i></a>\n          <a href=\"#\" style=\"color: var(--k-color-text-muted); display: inline-flex; transition: color 150ms;\" onmouseover=\"this.style.color='var(--k-color-primary)'\" onmouseout=\"this.style.color='var(--k-color-text-muted)'\" data-kid=\"130\"><i data-lucide=\"message-square\" style=\"width: 18px; height: 18px; stroke-width: 1.5;\" data-kid=\"131\"></i></a>\n          <a href=\"#\" style=\"color: var(--k-color-text-muted); display: inline-flex; transition: color 150ms;\" onmouseover=\"this.style.color='var(--k-color-primary)'\" onmouseout=\"this.style.color='var(--k-color-text-muted)'\" data-kid=\"132\"><i data-lucide=\"globe\" style=\"width: 18px; height: 18px; stroke-width: 1.5;\" data-kid=\"133\"></i></a>\n        </div>\n      </div>\n      <div data-kid=\"134\">\n        <h5 style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-sm); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.25em; color: var(--k-color-text-muted); margin: 0 0 var(--k-spacing-md) 0;\" data-kid=\"135\">Navigation</h5>\n        <ul style=\"list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--k-spacing-sm);\" data-kid=\"136\">\n          <li data-kid=\"137\"><a href=\"#\" style=\"font-family: var(--k-font-family-body); font-size: 14px; font-weight: var(--k-font-weight-normal); color: var(--k-color-text-primary); text-decoration: none; transition: color 150ms;\" onmouseover=\"this.style.color='var(--k-color-primary)'\" onmouseout=\"this.style.color='var(--k-color-text-primary)'\" data-kid=\"138\">Current Batch</a></li>\n          <li data-kid=\"139\"><a href=\"#\" style=\"font-family: var(--k-font-family-body); font-size: 14px; font-weight: var(--k-font-weight-normal); color: var(--k-color-text-primary); text-decoration: none; transition: color 150ms;\" onmouseover=\"this.style.color='var(--k-color-primary)'\" onmouseout=\"this.style.color='var(--k-color-text-primary)'\" data-kid=\"140\">The Craft</a></li>\n          <li data-kid=\"141\"><a href=\"#\" style=\"font-family: var(--k-font-family-body); font-size: 14px; font-weight: var(--k-font-weight-normal); color: var(--k-color-text-primary); text-decoration: none; transition: color 150ms;\" onmouseover=\"this.style.color='var(--k-color-primary)'\" onmouseout=\"this.style.color='var(--k-color-text-primary)'\" data-kid=\"142\">Inner Circle</a></li>\n          <li data-kid=\"143\"><a href=\"#\" style=\"font-family: var(--k-font-family-body); font-size: 14px; font-weight: var(--k-font-weight-normal); color: var(--k-color-text-primary); text-decoration: none; display: inline-flex; align-items: center; gap: 4px; transition: color 150ms;\" onmouseover=\"this.style.color='var(--k-color-primary)'\" onmouseout=\"this.style.color='var(--k-color-text-primary)'\" data-kid=\"144\">View on Etsy <span style=\"font-size: 11px;\" data-kid=\"145\">↗</span></a></li>\n        </ul>\n      </div>\n      <div data-kid=\"146\">\n        <h5 style=\"font-family: var(--k-font-family-body); font-size: var(--k-font-size-sm); font-weight: var(--k-font-weight-semibold); text-transform: uppercase; letter-spacing: 0.25em; color: var(--k-color-text-muted); margin: 0 0 var(--k-spacing-md) 0;\" data-kid=\"147\">Assistance</h5>\n        <ul style=\"list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--k-spacing-sm);\" data-kid=\"148\">\n          <li data-kid=\"149\"><span style=\"font-family: var(--k-font-family-body); font-size: 14px; font-weight: var(--k-font-weight-normal); color: var(--k-color-text-muted);\" data-kid=\"150\">Shipping &amp; Returns</span></li>\n          <li data-kid=\"151\"><span style=\"font-family: var(--k-font-family-body); font-size: 14px; font-weight: var(--k-font-weight-normal); color: var(--k-color-text-muted);\" data-kid=\"152\">Wholesale</span></li>\n          <li data-kid=\"153\"><a href=\"#\" style=\"font-family: var(--k-font-family-body); font-size: 14px; font-weight: var(--k-font-weight-normal); color: var(--k-color-text-primary); text-decoration: none; transition: color 150ms;\" onmouseover=\"this.style.color='var(--k-color-primary)'\" onmouseout=\"this.style.color='var(--k-color-text-primary)'\" data-kid=\"154\">Contact</a></li>\n        </ul>\n      </div>\n    </div>\n    <div style=\"border-top: var(--k-border-width-default) solid rgba(218,204,184,0.35); margin-top: 48px; padding-top: var(--k-spacing-lg); display: flex; justify-content: space-between; align-items: center;\" data-kid=\"155\">\n      <p style=\"font-family: var(--k-font-family-body); font-size: 11px; font-weight: var(--k-font-weight-normal); color: var(--k-color-text-muted); margin: 0;\" data-kid=\"156\">© 2026 Candera Studio. All rights reserved.</p>\n      <div style=\"display: flex; gap: var(--k-spacing-md);\" data-kid=\"157\">\n        <span style=\"font-family: var(--k-font-family-body); font-size: 11px; font-weight: var(--k-font-weight-normal); color: var(--k-color-text-muted); cursor: pointer;\" data-kid=\"158\">Privacy Policy</span>\n        <span style=\"font-family: var(--k-font-family-body); font-size: 11px; color: var(--k-color-border);\" data-kid=\"159\">·</span>\n        <span style=\"font-family: var(--k-font-family-body); font-size: 11px; font-weight: var(--k-font-weight-normal); color: var(--k-color-text-muted); cursor: pointer;\" data-kid=\"160\">Terms of Service</span>\n      </div>\n    </div>\n  </div>\n</footer>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"161\"></script>\n<script data-kid=\"162\">if (typeof lucide !== 'undefined') { lucide.createIcons(); }</script>\n",
