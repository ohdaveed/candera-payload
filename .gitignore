# Build outputs
dist/
build/

# Node modules
node_modules/

# OS
.DS_Store

# Next/Vercel
.next/
.vercel/
next-env.d.ts

# Payload default media upload directory
public/media/

# Public static files
public/robots.txt
public/sitemap*.xml

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/

# Claude Code local settings (session-specific, not for version control)
.claude/settings.local.json
.claude/skills/
.claude/worktrees/
.claude/settings.json

# VS Code local settings
.vscode/

# Temporary/blob reports
/blob-report/

# Ignore accidental saved query files that sometimes get created at repo root
# (example: a saved `ql -c SELECT ...` command gets written as a file)
ql*

# Env files: ignore all local/private envs, but keep the example template
.env
.env.local
.env.*.local
.env.*.bak
.env.*.secret
.env.*.key
.env.*
!.env.example

# TypeScript build info
tsconfig.tsbuildinfo

# Verification & Temporary Scripts
verify-fix.ts
scripts/verify-*.png

# Tool Logs & Agent Data
.playwright-mcp/
.serena/
.gemini/
.codex/
.entire/
.cache_ggshield

# Local screenshots & scratch output
/*.png
/output/

# Skills lock
skills-lock.json

# Local Proton Pass payloads (contain secret placeholders / values)
scripts/pass_payloads/*.json

# Generated pass output (contains resolved secrets)
.env.pass
scripts/merge-pass-env.py

# Python bytecode from local checks
scripts/__pycache__/
.neon
.env*
